{
	"$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/json-schema-for-oxlint/npm/oxlint/configuration_schema.json",
	"rules": {
		"no-unused-vars": "error",
		"no-console": "warn",
		"no-debugger": "error",
		"no-duplicate-case": "error",
		"no-eval": "error",
		"no-throw-literal": "error",
		"no-self-compare": "error",
		"eqeqeq": "error",
		"no-var": "error",
		"prefer-const": "error",
		"use-isnan": "error",
		"valid-typeof": "error"
	},
	"ignorePatterns": ["node_modules", "dist", "coverage", "*.config.js", "*.config.ts"]
}
